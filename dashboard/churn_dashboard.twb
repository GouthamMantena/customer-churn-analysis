          <datasource-dependencies datasource='federated.1aydnjw0boihzy166pm0b0li6wnb'>
            <column caption='Churned Customers' datatype='integer' name='[Calculation_1367839858188288]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM([Churn])' />
            </column>
            <column caption='Total Customers' datatype='integer' name='[Calculation_1367839866806273]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='COUNT([Churn])' />
            </column>
            <column caption='Churn Rate' datatype='real' name='[Calculation_1367839866937346]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM([Churn])/COUNT([Churn])' />
